<script>
  document.querySelectorAll('a[href="/how-to-play-xiangqi/"]').forEach((anchor) => {
    if (anchor.textContent?.includes("棋子与走法")) {
      anchor.setAttribute("href", "/pieces-and-moves/");
    }
  });

  const signupForm = document.querySelector('[data-replica-signup-form]');
  const signupStatus = document.querySelector('[data-signup-status]');

  if (signupForm instanceof HTMLFormElement && signupStatus instanceof HTMLElement) {
    const accountInput = signupForm.querySelector('#signup-account');
    const passwordInput = signupForm.querySelector('#signup-password');
    const confirmInput = signupForm.querySelector('#signup-confirm');

    const clearState = (input: Element | null) => {
      if (!(input instanceof HTMLInputElement)) return;
      input.classList.remove('is-invalid');
      input.removeAttribute('aria-invalid');
    };

    const setInvalid = (input: Element | null) => {
      if (!(input instanceof HTMLInputElement)) return;
      input.classList.add('is-invalid');
      input.setAttribute('aria-invalid', 'true');
    };

    signupForm.querySelectorAll('.replica-signup-page__input').forEach((input) => {
      input.addEventListener('input', () => clearState(input));
    });

    signupForm.addEventListener('submit', (event) => {
      event.preventDefault();
      signupStatus.textContent = '';
      signupStatus.classList.remove('is-error', 'is-success');

      const inputs = [accountInput, passwordInput, confirmInput].filter(
        (input) => input instanceof HTMLInputElement
      );

      inputs.forEach((input) => clearState(input));

      const emptyInput = inputs.find((input) => !input.value.trim());
      if (emptyInput) {
        setInvalid(emptyInput);
        signupStatus.textContent = `请填写${emptyInput.dataset.fieldLabel || '必填项'}。`;
        signupStatus.classList.add('is-error');
        emptyInput.focus();
        return;
      }

      if (passwordInput instanceof HTMLInputElement && confirmInput instanceof HTMLInputElement) {
        if (passwordInput.value !== confirmInput.value) {
          setInvalid(passwordInput);
          setInvalid(confirmInput);
          signupStatus.textContent = '两次输入的密码不一致，请重新确认。';
          signupStatus.classList.add('is-error');
          confirmInput.focus();
          return;
        }
      }

      signupStatus.textContent = '当前页面为本地复刻版，已完成前端校验，但未连接真实注册服务。';
      signupStatus.classList.add('is-success');
    });
  }
</script>

