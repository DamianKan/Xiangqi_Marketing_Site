---
import { replicaAssets } from "../../data/replica/assets";
import { zhTeamGroups } from "../../data/replica/team";
import type { ReplicaPage } from "../../data/replica/types";

const { page } = Astro.props as { page: ReplicaPage };
const isHome = page.type === "home";
const playCtas = page.ctas || [];
const isDownloadPage = page.type === "download";
const isJourneyHelpPage = page.id === "ZH-002";
const isPlayWithFriendPage = page.id === "ZH-007";
const isFirstGamePage = page.id === "ZH-006";
const isPieceGuidePage = page.id === "ZH-004";
const isTeamPage = page.id === "ZH-018";
const isFairPlayPage = page.id === "ZH-024";
const isRulesPage = page.id === "ZH-005";
const isLimitsPage = page.id === "ZH-021";
const isRatingPage = page.id === "ZH-012";
const isPuzzlePage = page.id === "ZH-008";
const isTournamentPage = page.id === "ZH-009";
const isInviteGuidePage = page.id === "ZH-010";
const isAnalysisPage = page.id === "ZH-010A";
const isComputerPage = page.id === "ZH-019";
const isPolitePage = page.id === "ZH-025";
const slicedSections = page.sections.slice(page.type === "home" ? 1 : 0);
const downloadLeadSections = isDownloadPage ? slicedSections.slice(0, 3) : [];
const contentSections = isDownloadPage ? slicedSections.slice(3) : slicedSections;
const journeyIntroSection = isJourneyHelpPage ? page.sections[0] : undefined;
const journeyRulesSection = isJourneyHelpPage ? page.sections[1] : undefined;
const journeyStepsSection = isJourneyHelpPage ? page.sections[2] : undefined;
const friendIntroSection = isPlayWithFriendPage ? page.sections[0] : undefined;
const friendCreateSection = isPlayWithFriendPage ? page.sections[1] : undefined;
const friendUsernameSection = isPlayWithFriendPage ? page.sections[2] : undefined;
const friendEmailLeadSection = isPlayWithFriendPage ? page.sections[3] : undefined;
const friendEmailActionSection = isPlayWithFriendPage ? page.sections[4] : undefined;
const friendEmailInviteSection = isPlayWithFriendPage ? page.sections[5] : undefined;
const friendAcceptIntroSection = isPlayWithFriendPage ? page.sections[6] : undefined;
const friendOnlineSection = isPlayWithFriendPage ? page.sections[7] : undefined;
const friendOfflineSection = isPlayWithFriendPage ? page.sections[8] : undefined;
const friendMoreSection = isPlayWithFriendPage ? page.sections[9] : undefined;
const puzzleIntroSection = isPuzzlePage ? page.sections[0] : undefined;
const puzzleEditorSection = isPuzzlePage ? page.sections[1] : undefined;
const puzzleCreateSection = isPuzzlePage ? page.sections[2] : undefined;
const puzzlePublishSection = isPuzzlePage ? page.sections[3] : undefined;
const puzzleCtaSection = isPuzzlePage ? page.sections[4] : undefined;

const articleHeading =
  page.locale === "en"
    ? "Articles & Blogs"
    : page.locale === "vi"
      ? "Bài viết và blog"
      : page.locale === "zh-Hant"
        ? "教學文章"
        : "教学文章";

const faqHeading =
  page.locale === "en"
    ? "FAQs"
    : page.locale === "vi"
      ? "Câu hỏi thường gặp"
      : page.locale === "zh-Hant"
        ? "常見問題"
        : "常见问题";

const articleMoreLabel =
  page.locale === "en"
    ? "View All"
    : page.locale === "vi"
      ? "Xem tất cả"
      : "更多";

const articleReadMoreLabel =
  page.locale === "en"
    ? "Read More"
    : page.locale === "vi"
      ? "Đọc thêm"
      : page.locale === "zh-Hant"
        ? "閱讀更多"
        : "阅读更多";

const articleIndexHref =
  page.locale === "en" ? "/news/" : page.locale === "vi" ? "/vi/" : "/articles/";

const linkAttrs = (external?: boolean) =>
  external ? { target: "_blank", rel: "noreferrer" } : {};

const xiangqiPieces = [
  {
    symbol: "帅",
    name: "帅（将）",
    accent: "red",
    image: "/images/pieces/general-move.svg",
    imageAlt: "帅在九宫内前后左右移动的示意图",
    move: "每次走一格，只能在九宫内前后左右移动。",
    feature: "全局核心，任何时候都不能暴露在将帅照面或连续攻击下。",
    tip: "先保帅，再谋攻。"
  },
  {
    symbol: "仕",
    name: "仕（士）",
    accent: "dark",
    image: "/images/pieces/advisor-move.svg",
    imageAlt: "仕沿九宫斜线移动的示意图",
    move: "沿九宫斜线走一格，始终不能离开九宫。",
    feature: "贴身护将，负责补位和封锁九宫斜线。",
    tip: "双仕齐全，防守更稳。"
  },
  {
    symbol: "相",
    name: "相（象）",
    accent: "red",
    image: "/images/pieces/elephant-move.svg",
    imageAlt: "相走田字且不过河的示意图",
    move: "走田字，对角两格；若中间有子，就会被塞象眼。",
    feature: "不能过河，主要负责本方半场的联防和稳固。",
    tip: "看清象眼，再决定落点。"
  },
  {
    symbol: "车",
    name: "车",
    accent: "dark",
    image: "/images/pieces/chariot-move.svg",
    imageAlt: "车横竖直走的示意图",
    move: "横竖直走，格数不限，中间不能有棋子阻挡。",
    feature: "主力最强，适合封线、压制和远距离进攻。",
    tip: "出车越早，通常越主动。"
  },
  {
    symbol: "马",
    name: "马",
    accent: "red",
    image: "/images/pieces/horse-move.svg",
    imageAlt: "马走日字并受马腿限制的示意图",
    move: "走日字，先直后斜；第一步被堵住就会被蹩马腿。",
    feature: "善于穿插和制造连续战术，但特别怕被卡住马腿。",
    tip: "落马前先看马腿。"
  },
  {
    symbol: "炮",
    name: "炮（砲）",
    accent: "dark",
    image: "/images/pieces/cannon-move.svg",
    imageAlt: "炮隔子吃子的示意图",
    move: "不吃子时像车直走；吃子时中间必须隔着恰好一个棋子。",
    feature: "最擅长远程牵制和突然打击，中局威胁很大。",
    tip: "有炮架时，炮的威力最大。"
  },
  {
    symbol: "兵",
    name: "兵（卒）",
    accent: "red",
    image: "/images/pieces/soldier-move.svg",
    imageAlt: "兵过河前后走法变化的示意图",
    move: "过河前只能向前一格；过河后可向前或横走，但不能后退。",
    feature: "前期推进慢，过河后会持续压缩对方空间。",
    tip: "残局里过河兵价值很高。"
  }
];
---

{isJourneyHelpPage || isPlayWithFriendPage || isFirstGamePage || isPieceGuidePage || isTeamPage || isFairPlayPage || isRulesPage || isLimitsPage || isRatingPage || isPuzzlePage || isTournamentPage || isInviteGuidePage || isAnalysisPage || isComputerPage || isPolitePage ? null : isHome ? (
  <section class="replica-hero" aria-labelledby="page-title">
    <div class="replica-hero__veil"></div>
    <div class="replica-hero__content">
      <span class="replica-hero__eyebrow">相弈象棋 Xiangqi.com</span>
      <h1 id="page-title">{page.heroTitle}</h1>
      <p class="replica-hero__lead">{page.description}</p>
      <div class="replica-actions replica-hero__actions">
        {playCtas.map((cta) => (
          <a
            class:list={["replica-btn", cta.variant === "secondary" && "replica-btn--secondary"]}
            href={cta.href}
            {...linkAttrs(cta.external)}
          >
            {cta.label}
          </a>
        ))}
      </div>
    </div>
  </section>
) : (
  <section class:list={["replica-subhero", isDownloadPage && "replica-subhero--download"]}>
    <div class:list={["replica-container", page.type !== "home" && !isDownloadPage && "replica-container--narrow"]}>
      <p class="replica-kicker">Xiangqi.com</p>
      <h1 id="page-title">{page.heroTitle}</h1>
      {(page.heroSubtitle || page.description) && <p>{page.heroSubtitle || page.description}</p>}
      {playCtas.length > 0 && (
        <div class="replica-actions replica-actions--left">
          {playCtas.map((cta) => (
            <a
              class:list={["replica-btn", cta.variant === "secondary" && "replica-btn--secondary"]}
              href={cta.href}
              {...linkAttrs(cta.external)}
            >
              {cta.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
)}

{page.type === "home" && page.sections[0] && (
  <section class="replica-red replica-intro">
    <div class="replica-container replica-two-col">
      <div class="replica-intro__art">
        <img
          src={page.sections[0].image || replicaAssets.intro}
          alt={page.sections[0].imageAlt || page.sections[0].title}
          loading="lazy"
        />
      </div>
      <div class="replica-intro__copy">
        <h2>{page.sections[0].title}</h2>
        {page.sections[0].body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>
)}

{isJourneyHelpPage ? (
  <section class="replica-help-doc">
    <div class="replica-help-doc__inner">
      <h1 class="replica-help-doc__title">来 Xiangqi.com 相弈象棋，下中国象棋</h1>
      <p class="replica-help-doc__intro">
        与世界各地的棋手一起学习、对弈和分享。即便您是象棋新手，也没关系！
        <a href="/team/">我们</a>
        将随时为您提供帮助，陪伴您成长。
      </p>

      {journeyIntroSection && (
        <article class="replica-help-doc__section">
          <h2>{journeyIntroSection.title}</h2>
          {journeyIntroSection.links && (
            <ul class="replica-help-doc__link-list">
              {journeyIntroSection.links.map((link) => (
                <li>
                  <a href={link.href} {...linkAttrs(link.external)}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </article>
      )}

      {journeyRulesSection && (
        <article class="replica-help-doc__section">
          <h2>{journeyRulesSection.title}</h2>
          {journeyRulesSection.body.map((paragraph) => <p>{paragraph}</p>)}
          {journeyRulesSection.links && (
            <ul class="replica-help-doc__link-list replica-help-doc__link-list--compact">
              {journeyRulesSection.links.map((link) => (
                <li>
                  <a href={link.href} {...linkAttrs(link.external)}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </article>
      )}

      {journeyStepsSection && (
        <article class="replica-help-doc__section">
          <h2>{journeyStepsSection.title}</h2>
          <ol class="replica-help-doc__steps">
            <li><a href="https://play.xiangqi.com/account/signup" {...linkAttrs(true)}>注册</a></li>
            <li>输入用户名、邮箱、密码和国家/地区，完善头像与自我介绍。示例：<a href="https://play.xiangqi.com/@/paul" {...linkAttrs(true)}>@paul的个人页面</a></li>
            <li>打开收件箱，点击验证邮件中的链接完成账号验证。</li>
            <li>登录后进入<a href="https://play.xiangqi.com/" {...linkAttrs(true)}>游戏大厅</a>，可以创建公开对局、观看正在进行的对弈，或与其他棋手聊天。</li>
            <li>开始对弈前，也请留意<a href="/polite/">文明礼貌</a>规则；如果想更快上手，可以继续查看<a href="/first-game/">开始第一盘对局</a>和<a href="/play-with-a-friend/">邀请好友对战</a>。</li>
          </ol>
        </article>
      )}
    </div>
  </section>
) : isLimitsPage ? (
  <section class="replica-help-doc replica-help-doc--limits">
    <div class="replica-help-doc__inner">
      {page.sections[0]?.body.map((paragraph) => (
        <p class="replica-help-doc__lead">{paragraph}</p>
      ))}

      {page.sections.slice(1).map((section) => (
        <article class="replica-help-doc__section">
          <h2>{section.title}</h2>
          {section.body.map((paragraph) => <p>{paragraph}</p>)}
          {section.links && (
            <ul class="replica-help-doc__link-list replica-help-doc__link-list--compact">
              {section.links.map((link) => (
                <li>
                  <a href={link.href} {...linkAttrs(link.external)}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>
) : isPuzzlePage ? (
  <section class="replica-puzzle-page">
    <div class="replica-puzzle-page__inner">
      {puzzleIntroSection && (
        <section class="replica-puzzle-page__intro">
          <p>
            {puzzleIntroSection.body[0]}
            {puzzleIntroSection.links?.[0] && (
              <>
                {" "}
                <a href={puzzleIntroSection.links[0].href} {...linkAttrs(puzzleIntroSection.links[0].external)}>
                  {puzzleIntroSection.links[0].label}
                </a>
              </>
            )}
          </p>
        </section>
      )}

      {[puzzleEditorSection, puzzleCreateSection, puzzlePublishSection].filter(Boolean).map((section) => (
        <section class="replica-puzzle-page__feature">
          {section?.image && (
            <figure class="replica-puzzle-page__figure">
              <img src={section.image} alt={section.imageAlt || section.title} loading="lazy" />
            </figure>
          )}
          <div class="replica-puzzle-page__copy">
            <h2>{section?.title}</h2>
            {section?.body.map((paragraph) => (
              paragraph.startsWith("· ") ? (
                <p class="replica-puzzle-page__bullet">{paragraph}</p>
              ) : (
                <p>{paragraph}</p>
              )
            ))}
          </div>
        </section>
      ))}

      {page.faq && page.faq.length > 0 && (
        <section class="replica-puzzle-page__faq">
          <h2>常见问题与注意事项</h2>
          <div class="replica-puzzle-page__faq-list">
            {page.faq.map((item, index) => (
              <details open={index === 0}>
                <summary>{item.question}</summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      {puzzleCtaSection && (
        <section class="replica-puzzle-page__cta">
          <h2>{puzzleCtaSection.title}</h2>
          {puzzleCtaSection.body.map((paragraph) => <p>{paragraph}</p>)}
          {puzzleCtaSection.links?.[0] && (
            <a
              class="replica-puzzle-page__button"
              href={puzzleCtaSection.links[0].href}
              {...linkAttrs(puzzleCtaSection.links[0].external)}
            >
              {puzzleCtaSection.links[0].label}
            </a>
          )}
        </section>
      )}
    </div>
  </section>
) : isComputerPage ? (
  <section class="replica-computer-page">
    <div class="replica-computer-page__inner">
      <header class="replica-computer-page__hero">
        <h1>如何开始人机对战？</h1>
        <p>和电脑对战可帮助棋手练习不同等级的对局和新战术。</p>
        <ol class="replica-computer-page__steps">
          <li>
            <a href="https://play.xiangqi.com/" {...linkAttrs(true)}>前往游戏大厅</a>
          </li>
          <li>选择电脑对手</li>
        </ol>

        <figure class="replica-computer-page__hero-figure">
          <img src="/mirror/computer-step-hero.png" alt="人机对战等级选择界面截图" loading="lazy" />
        </figure>

        <div class="replica-computer-page__hero-notes">
          <p>难度最低的是1级的 @petr</p>
          <p>难度最高的是5级的 @zhixuan(稚轩)</p>
          <p class="replica-computer-page__warm-note">温馨提示：人机对战不会影响棋手排名。</p>
        </div>
      </header>

      <section class="replica-computer-page__section replica-computer-page__section--bordered">
        <h2>练习</h2>
        <p class="replica-computer-page__lead">学习虽难，但裨益良多！</p>
        <p>
          象棋不简单，初学者甚至可能很难击败难度最低的电脑（1级）。为此，我们设置了“悔棋”这一选项。如认为行棋错误，可随时撤销，并重新落子，直至满意为止。
        </p>

        <div class="replica-computer-page__gallery">
          <figure class="replica-computer-page__figure">
            <img src="/mirror/computer-practice.png" alt="悔棋功能在对局中的位置示意图" loading="lazy" />
            <figcaption>学会用悔棋打败电脑</figcaption>
          </figure>
          <figure class="replica-computer-page__figure replica-computer-page__figure--secondary">
            <img src="/mirror/computer-undo.png" alt="设置面板中的悔棋按钮示意图" loading="lazy" />
          </figure>
        </div>

        <div class="replica-computer-page__cta-wrap">
          <a class="replica-computer-page__cta" href="https://play.xiangqi.com/" {...linkAttrs(true)}>
            马上与电脑对战
          </a>
        </div>
      </section>

      <section class="replica-computer-page__section replica-computer-page__next">
        <h2>
          下一步：
          <a href="/how-to-play/">象棋规则</a>
        </h2>
        <ul class="replica-computer-page__next-links">
          <li>
            <span aria-hidden="true">❓</span>
            <a href="/how-to-play/">象棋规则</a>
          </li>
          <li>
            <a href="/how-to-play-xiangqi/">棋子与走法</a>
          </li>
          <li>
            <span aria-hidden="true">✅</span>
            <a href="https://play.xiangqi.com/account/signup" {...linkAttrs(true)}>创建账号</a>
          </li>
        </ul>
      </section>

      <section class="replica-computer-page__section">
        <h2>技术说明：我们使用的象棋引擎</h2>
        <p>
          象棋网目前正在使用由 Vin 象棋团队开发的开源象棋引擎 Pikafish。它是一个非常强大的免费 UCI 象棋引擎，基于 NNUE 神经网络技术开发。Pikafish团队的官方网站在
          <a href="http://pikafish.org/" {...linkAttrs(true)}>这里</a>。
        </p>
      </section>

      <section class="replica-computer-page__section">
        <h3>功能</h3>
        <p>
          截至目前，人机对战不限时，也不计入积分。棋手执红子，电脑执黑子。不过，我们随后也计划推出限时人机对战。由于电脑发挥的是最高水平，因此对于刚接触并仍在学习象棋的棋手来说，对手很难击败。
        </p>
      </section>

      <section class="replica-computer-page__section">
        <h3>展望未来</h3>
        <p>行棋和对局分析</p>
        <p>
          如需了解更多我们即将推出的内容，请参阅
          <a href="https://www.zh.xiangqi.com/roadmap/" {...linkAttrs(true)}>产品路线图</a>。
        </p>
      </section>
    </div>
  </section>
) : isPlayWithFriendPage ? (
  <section class="replica-play-friend">
    <div class="replica-play-friend__inner">
      <header class="replica-play-friend__hero">
        <h1>如何与好友对战？</h1>
      </header>

      {friendIntroSection && (
        <section class="replica-play-friend__intro">
          {friendIntroSection.body.map((paragraph) => (
            <p>
              {paragraph}
              {paragraph.includes("邀请他们注册。") && friendIntroSection.links?.[0] && (
                <>
                  {" "}
                  <a href={friendIntroSection.links[0].href} {...linkAttrs(friendIntroSection.links[0].external)}>
                    {friendIntroSection.links[0].label}
                  </a>
                </>
              )}
            </p>
          ))}
        </section>
      )}

      {friendCreateSection && (
        <section class="replica-play-friend__section">
          <h2>{friendCreateSection.title}</h2>
          <div class="replica-play-friend__split">
            <div class="replica-play-friend__copy">
              <h3>{friendUsernameSection?.title}</h3>
              <ol class="replica-play-friend__steps">
                <li>
                  进入官网
                  {" "}
                  <a href={friendCreateSection.links?.[0]?.href || "https://play.xiangqi.com/"} {...linkAttrs(true)}>
                    游戏大厅
                  </a>
                  。
                </li>
                <li>点击“+创建对局”，选择对局类型。</li>
              </ol>
            </div>
            {friendUsernameSection?.image && (
              <figure class="replica-play-friend__figure">
                <img src={friendUsernameSection.image} alt={friendUsernameSection.imageAlt || friendUsernameSection.title} loading="lazy" />
              </figure>
            )}
          </div>

          <div class="replica-play-friend__split replica-play-friend__split--reverse">
            {friendEmailLeadSection?.image && (
              <figure class="replica-play-friend__figure">
                <img src={friendEmailLeadSection.image} alt={friendEmailLeadSection.imageAlt || friendEmailLeadSection.title} loading="lazy" />
              </figure>
            )}
            <div class="replica-play-friend__copy">
              <h3>{friendEmailLeadSection?.title}</h3>
              <ol class="replica-play-friend__steps replica-play-friend__steps--continued" start={3}>
                {friendUsernameSection?.body.map((item) => (
                  <li>{item.replace(/^\d+\.\s*/, "")}</li>
                ))}
              </ol>
            </div>
          </div>
        </section>
      )}

      {(friendEmailActionSection || friendEmailInviteSection) && (
        <section class="replica-play-friend__section">
          <h3>{friendEmailActionSection?.title}</h3>
          <div class="replica-play-friend__email-layout">
            <div class="replica-play-friend__copy">
              {friendEmailActionSection?.body.map((paragraph) => <p>{paragraph}</p>)}
              {friendEmailInviteSection && (
                <>
                  <h4>{friendEmailInviteSection.title}</h4>
                  {friendEmailInviteSection.body.map((paragraph) => <p>{paragraph}</p>)}
                </>
              )}
            </div>
