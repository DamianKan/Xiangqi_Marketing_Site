const splitHighlightedNumber = (item: string) => {
  const match = item.match(/\d[\d,]*/);
  if (!match || match.index === undefined) return undefined;

  return {
    before: item.slice(0, match.index),
    value: match[0],
    after: item.slice(match.index + match[0].length)
  };
};

const stripLeadingSectionNumber = (item: string) => item.replace(/^\d+(?:\.\d+)?\.\s*/, "");

