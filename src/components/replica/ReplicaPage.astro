---
import { replicaAssets } from "../../data/replica/assets";
import type { ReplicaPage } from "../../data/replica/types";

const { page } = Astro.props as { page: ReplicaPage };
const isHome = page.type === "home";
const playCtas = page.ctas || [];
const isDownloadPage = page.type === "download";
const slicedSections = page.sections.slice(page.type === "home" ? 1 : 0);
const downloadLeadSections = isDownloadPage ? slicedSections.slice(0, 3) : [];
const contentSections = isDownloadPage ? slicedSections.slice(3) : slicedSections;

const articleHeading =
  page.locale === "en"
    ? "Articles & Blogs"
    : page.locale === "vi"
      ? "Bài viết và blog"
      : page.locale === "zh-Hant"
        ? "教學文章"
        : "教学文章";

const faqHeading =
  page.locale === "en"
    ? "FAQs"
    : page.locale === "vi"
      ? "Câu hỏi thường gặp"
      : page.locale === "zh-Hant"
        ? "常見問題"
        : "常见问题";

const articleMoreLabel =
  page.locale === "en"
    ? "View All"
    : page.locale === "vi"
      ? "Xem tất cả"
      : "更多";

const articleReadMoreLabel =
  page.locale === "en"
    ? "Read More"
    : page.locale === "vi"
      ? "Đọc thêm"
      : page.locale === "zh-Hant"
        ? "閱讀更多"
        : "阅读更多";

const articleIndexHref =
  page.locale === "en" ? "/news/" : page.locale === "vi" ? "/vi/" : "/articles/";

const linkAttrs = (external?: boolean) =>
  external ? { target: "_blank", rel: "noreferrer" } : {};
---

{isHome ? (
  <section class="replica-hero" aria-labelledby="page-title">
    <div class="replica-hero__veil"></div>
    <div class="replica-hero__content">
      <span class="replica-hero__eyebrow">相弈象棋 Xiangqi.com</span>
      <h1 id="page-title">{page.heroTitle}</h1>
      <p class="replica-hero__lead">{page.description}</p>
      <div class="replica-actions replica-hero__actions">
        {playCtas.map((cta) => (
          <a
            class:list={["replica-btn", cta.variant === "secondary" && "replica-btn--secondary"]}
            href={cta.href}
            {...linkAttrs(cta.external)}
          >
            {cta.label}
          </a>
        ))}
      </div>
    </div>
  </section>
) : (
  <section class:list={["replica-subhero", isDownloadPage && "replica-subhero--download"]}>
    <div class:list={["replica-container", page.type !== "home" && !isDownloadPage && "replica-container--narrow"]}>
      <p class="replica-kicker">Xiangqi.com</p>
      <h1 id="page-title">{page.heroTitle}</h1>
      {(page.heroSubtitle || page.description) && <p>{page.heroSubtitle || page.description}</p>}
      {playCtas.length > 0 && (
        <div class="replica-actions replica-actions--left">
          {playCtas.map((cta) => (
            <a
              class:list={["replica-btn", cta.variant === "secondary" && "replica-btn--secondary"]}
              href={cta.href}
              {...linkAttrs(cta.external)}
            >
              {cta.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
)}

{page.type === "home" && page.sections[0] && (
  <section class="replica-red replica-intro">
    <div class="replica-container replica-two-col">
      <div class="replica-intro__art">
        <img
          src={page.sections[0].image || replicaAssets.intro}
          alt={page.sections[0].imageAlt || page.sections[0].title}
          loading="lazy"
        />
      </div>
      <div class="replica-intro__copy">
        <h2>{page.sections[0].title}</h2>
        {page.sections[0].body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>
)}

<section class:list={["replica-content", page.type !== "home" && "replica-content--first"]}>
  <div class:list={["replica-container", page.type !== "home" && !isDownloadPage && "replica-container--narrow"]}>
    {isDownloadPage && downloadLeadSections.length > 0 && (
      <div class="replica-download-grid">
        {downloadLeadSections.map((section) => (
          <article class="replica-download-card">
            <div class="replica-download-card__copy">
              <h2>{section.title}</h2>
              {section.body.map((paragraph) => <p>{paragraph}</p>)}
              {section.links && (
                <div class="replica-download-card__actions">
                  {section.links.map((link) => (
                    <a
                      class="replica-btn replica-btn--secondary"
                      href={link.href}
                      {...linkAttrs(link.external)}
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
            {section.image && (
              <a
                class="replica-download-card__badge"
                href={section.links?.[0]?.href || "#"}
                {...linkAttrs(section.links?.[0]?.external)}
              >
                <img src={section.image} alt={section.imageAlt || section.title} loading="lazy" />
              </a>
            )}
          </article>
        ))}
      </div>
    )}

    <div class="replica-section-grid">
      {contentSections.map((section, index) => (
        <article
          class:list={[
            "replica-section",
            page.type !== "home" && "replica-section--document",
            index % 2 === 1 && isHome && "replica-section--alt",
            isHome && index < 2 && "replica-section--feature",
            isHome && index >= 2 && "replica-section--story"
          ]}
          id={`section-${index + 1}`}
        >
          {section.image && (
            <img src={section.image} alt={section.imageAlt || section.title} loading="lazy" />
          )}
          <div class="replica-section__body">
            <h2>{section.title}</h2>
            {section.gallery && section.gallery.length > 0 && (
              <div class="replica-showcase-grid">
                {section.gallery.map((item) => (
                  <figure class="replica-showcase-card">
                    <figcaption>{item.title}</figcaption>
                    <img src={item.image} alt={item.imageAlt || item.title} loading="lazy" />
                  </figure>
                ))}
              </div>
            )}
            {section.body.map((paragraph) => <p>{paragraph}</p>)}
            {section.list && (
              <ul>
                {section.list.map((item) => <li>{item}</li>)}
              </ul>
            )}
            {section.links && (
              <p class="replica-link-row">
                {section.links.map((link) => (
                  <a href={link.href} {...linkAttrs(link.external)}>
                    {link.label}
                  </a>
                ))}
              </p>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

{page.articleCards && page.articleCards.length > 0 && (
  <section class="replica-articles">
    <div class:list={["replica-container", !isHome && "replica-container--narrow"]}>
      <div class="replica-section-head">
        <h2>{articleHeading}</h2>
        <a class="replica-more-link" href={articleIndexHref}>
          {articleMoreLabel}
        </a>
      </div>
      <div class="replica-card-grid">
        {page.articleCards.map((article) => (
          <a class="replica-card" href={article.href}>
            {article.image && (
              <div class="replica-card__media">
                <img src={article.image} alt={article.title} loading="lazy" />
              </div>
            )}
            {article.date && <p class="replica-date">{article.date}</p>}
            <h3>{article.title}</h3>
            <p>{article.excerpt}</p>
            <span class="replica-card__more">{articleReadMoreLabel}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

{page.faq && page.faq.length > 0 && (
  <section class="replica-faq">
    <div class="replica-container">
      <h2>{faqHeading}</h2>
      <div class="replica-faq__list">
        {page.faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}
