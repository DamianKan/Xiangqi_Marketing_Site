  </section>
)}

{!isJourneyHelpPage && !isPlayWithFriendPage && !isFirstGamePage && !isPieceGuidePage && !isTeamPage && !isRulesPage && !isRatingPage && !isPuzzlePage && !isTournamentPage && !isComputerPage && page.faq && page.faq.length > 0 && (
  <section class="replica-faq">
    <div class="replica-container">
      <h2>{faqHeading}</h2>
      <div class="replica-faq__list">
        {page.faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
)}






