const content = footerContent[locale];
const linkAttrs = (external?: boolean) => (external ? { target: "_blank", rel: "noreferrer" } : {});
---

<footer class="replica-footer">
  <div class="replica-footer__inner">
    <div class="replica-footer__brand">
      <h2>{content.brand}</h2>
    </div>

    <div class="replica-footer__grid">
      {content.columns.map((column) => (
        <div class="replica-footer__column">
          <h3>{column.title}</h3>
          <nav class="replica-footer__links" aria-label={column.title}>
            {column.links.map((link) => (
              <a href={link.href} {...linkAttrs(link.external)}>
                {link.label}
              </a>
            ))}
          </nav>
        </div>
      ))}
    </div>

    <div class="replica-footer__downloads" aria-label="Download app">
      {content.downloads.map((badge, index) => (
        <a
          class:list={["replica-store-badge", `replica-store-badge--${index + 1}`]}
          href={badge.href}
          {...linkAttrs(badge.external)}
        >
          <img src={badge.image} alt={badge.imageAlt} loading="lazy" />
        </a>
      ))}
    </div>

    <div class="replica-footer__meta">
      <p class="replica-footer__copyright">{content.copyright}</p>
      <p class="replica-footer__social">
        <span>{content.socialLabel}</span>
        {content.socialLinks.map((link) => (
          <a href={link.href} {...linkAttrs(link.external)}>
            {link.label}
          </a>
        ))}
      </p>
      <p class="replica-footer__whatsapp">
        <a href={content.whatsapp.href} {...linkAttrs(content.whatsapp.external)}>
          {content.whatsapp.label}
        </a>
      </p>
    </div>
  </div>
</footer>
