---
import BaseLayout from "../../layouts/BaseLayout.astro";
import articles from "../../data/articles.json";
import site from "../../data/site.json";
import { buildArticleStructuredData } from "../../utils/structuredData";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const canonicalPath = `/news/${article.slug}/`;
const canonical = new URL(canonicalPath, site.siteUrl).toString();
const articleStructuredData = buildArticleStructuredData({
  title: `${article.title} - 相弈象棋`,
  description: article.description,
  canonical,
  imageUrl: new URL("/images/xiangqi-og.svg", site.siteUrl).toString(),
  datePublished: article.date,
  dateModified: article.updatedAt || article.updated,
  authorName: article.author
});
---

<BaseLayout
  title={`${article.title} - 相弈象棋`}
  description={article.description}
  canonicalPath={canonicalPath}
  structuredData={articleStructuredData}
>
  <article class="section">
    <div class="container content-panel">
      <p class="eyebrow">News</p>
      <h1>{article.title}</h1>
      <p class="meta-line">发布：{article.date} / 更新：{article.updated} / 作者：{article.author}</p>
      {article.body.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </article>
</BaseLayout>
