---
import ReplicaLayout from "../layouts/ReplicaLayout.astro";
---

<ReplicaLayout
  title="产品筛选 - 相弈象棋"
  description="复刻相弈象棋源站当前 sys-pr 页面：价格区间筛选、当前条件搜索、排序表头与空结果提示。"
  route="/sys-pr/"
  locale="zh-CN"
>
  <section class="sys-pr-page">
    <div class="sys-pr-page__inner">
      <div class="sys-pr-page__toolbar" aria-label="产品筛选工具栏">
        <div class="sys-pr-page__price-range" aria-label="价格区间">
          <span class="sys-pr-page__range-label">价格区间：</span>
          <label class="sys-pr-page__price-field">
            <span class="sr-only">最低价格</span>
            <input type="text" inputmode="numeric" placeholder="￥" aria-label="最低价格" />
          </label>
          <span class="sys-pr-page__range-separator">-</span>
          <label class="sys-pr-page__price-field">
            <span class="sr-only">最高价格</span>
            <input type="text" inputmode="numeric" placeholder="￥" aria-label="最高价格" />
          </label>
          <button type="button" class="sys-pr-page__confirm">确定</button>
        </div>

        <label class="sys-pr-page__search" aria-label="当前条件下搜索">
          <input type="text" placeholder="当前条件下搜索" aria-label="当前条件下搜索" />
          <span class="sys-pr-page__search-icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" focusable="false" aria-hidden="true">
              <circle cx="8.5" cy="8.5" r="5.5"></circle>
              <path d="M12.8 12.8L17 17"></path>
            </svg>
          </span>
        </label>
      </div>

      <div class="sys-pr-page__sortbar" role="table" aria-label="筛选结果排序">
        <a class="sys-pr-page__sort is-active" href="/sys-pr/" aria-label="按名称排序">
          <span>名称</span>
          <span class="sys-pr-page__sort-arrows" aria-hidden="true">
            <i class="is-up"></i>
            <i></i>
          </span>
        </a>
        <a class="sys-pr-page__sort" href="/sys-pr/" aria-label="按时间排序">时间</a>
        <a class="sys-pr-page__sort" href="/sys-pr/" aria-label="按价格排序">价格</a>
      </div>

      <div class="sys-pr-page__empty" aria-live="polite">
        <div class="sys-pr-page__empty-figure" aria-hidden="true">
          <svg viewBox="0 0 180 180" focusable="false">
            <ellipse cx="90" cy="154" rx="34" ry="7" fill="rgba(203, 193, 182, 0.42)"></ellipse>
            <path
              d="M103 28c9 0 17 7 17 17v15h6c4 0 8 3 8 8 0 2-1 4-2 5l-9 17v42H57V90L48 73c-1-2-2-3-2-5 0-5 4-8 8-8h6V45c0-10 8-17 17-17h26Z"
              fill="none"
              stroke="#c8c1b8"
              stroke-width="3.2"
              stroke-linejoin="round"
            />
            <path d="M71 42c0-7 6-13 13-13h12c7 0 13 6 13 13" fill="none" stroke="#c8c1b8" stroke-width="3.2" />
            <path d="M65 60h50" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M70 132h40" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M79 82c4 0 7 3 7 7v21" fill="none" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M101 82c-4 0-7 3-7 7v21" fill="none" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M84 119c2 3 4 5 6 5s4-2 6-5" fill="none" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M77 77h8" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M95 77h8" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M53 93c-8 0-14-5-14-12" fill="none" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M127 93c8 0 14-5 14-12" fill="none" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M126 27c6-6 15-7 21-2 6 5 6 14 1 20" fill="none" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
            <path d="M142 18c2-6 8-10 14-10 8 0 14 6 14 14 0 6-4 12-10 14" fill="none" stroke="#c8c1b8" stroke-width="3.2" stroke-linecap="round" />
          </svg>
        </div>
        <p>未搜索到相关结果</p>
      </div>
    </div>
  </section>
</ReplicaLayout>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  body[data-route="/sys-pr/"] {
    background: #ede8e0;
  }

  body[data-route="/sys-pr/"] .replica-header {
    background: rgba(251, 247, 240, 0.92);
  }

  body[data-route="/sys-pr/"] main {
    min-height: 0;
  }

  .sys-pr-page {
    padding: 18px 0 0;
    background: #ede8e0;
  }

  .sys-pr-page__inner {
    width: min(1080px, calc(100vw - 40px));
    margin: 0 auto;
    color: #664f4c;
  }

  .sys-pr-page__toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 0.46fr);
    align-items: start;
    gap: 22px;
  }

  .sys-pr-page__price-range {
    min-height: 58px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 10px;
    padding: 12px 22px;
    background: rgba(240, 234, 226, 0.72);
    border: 1px solid rgba(219, 210, 199, 0.74);
  }

  .sys-pr-page__range-label {
    color: #5f5651;
    font-size: 14px;
    line-height: 1;
    white-space: nowrap;
  }

  .sys-pr-page__price-field input,
  .sys-pr-page__search input {
    width: 100%;
    border: 1px solid #d8d2ca;
    background: #fff;
    color: #6a5d56;
    font: inherit;
    outline: none;
  }

  .sys-pr-page__price-field {
    width: 76px;
  }

  .sys-pr-page__price-field input {
    height: 34px;
    padding: 0 10px;
    font-size: 14px;
  }

  .sys-pr-page__price-field input::placeholder,
  .sys-pr-page__search input::placeholder {
    color: #b4aca3;
  }

  .sys-pr-page__range-separator {
    color: #5f5651;
    font-size: 16px;
    line-height: 1;
  }

  .sys-pr-page__confirm {
    min-width: 72px;
    height: 34px;
    border: 1px solid #d8d2ca;
    background: #fff;
    color: #4e433d;
    cursor: pointer;
  }

  .sys-pr-page__search {
    position: relative;
    display: block;
    min-height: 40px;
  }

  .sys-pr-page__search input {
    height: 40px;
    padding: 0 52px 0 12px;
    font-size: 14px;
  }

  .sys-pr-page__search-icon {
    position: absolute;
    top: 50%;
    right: 13px;
    width: 20px;
    height: 20px;
    color: #1c1c1c;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .sys-pr-page__search-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .sys-pr-page__sortbar {
    display: grid;
    grid-template-columns: 90px 90px 90px;
    margin-top: 20px;
    background: #fff;
    border: 1px solid rgba(227, 223, 218, 0.92);
  }

  .sys-pr-page__sort {
    min-height: 50px;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 4px;
    padding: 0 22px;
    color: #332f2c;
    font-size: 14px;
    border-right: 1px solid rgba(227, 223, 218, 0.92);
  }

  .sys-pr-page__sort:last-child {
    border-right: 0;
  }

  .sys-pr-page__sort.is-active {
    font-weight: 500;
  }

  .sys-pr-page__sort-arrows {
    display: inline-grid;
    gap: 2px;
  }

  .sys-pr-page__sort-arrows i {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 5px solid #d8d2ca;
  }

  .sys-pr-page__sort-arrows .is-up {
    border-bottom-color: #ef4136;
  }

  .sys-pr-page__empty {
    min-height: 395px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 44px 0 82px;
    text-align: center;
  }

  .sys-pr-page__empty-figure {
    width: min(170px, 32vw);
    color: #cbc1b6;
  }

  .sys-pr-page__empty-figure svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .sys-pr-page__empty p {
    margin: 22px 0 0;
    color: #342d2a;
    font-size: 14px;
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .sys-pr-page {
      padding-top: 14px;
    }

    .sys-pr-page__inner {
      width: min(100vw - 30px, 1080px);
    }

    .sys-pr-page__toolbar {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .sys-pr-page__search {
      width: min(100%, 340px);
      justify-self: end;
    }
  }

  @media (max-width: 640px) {
    .sys-pr-page {
      padding-top: 10px;
    }

    .sys-pr-page__inner {
      width: calc(100vw - 24px);
    }

    .sys-pr-page__price-range {
      gap: 10px 8px;
      padding: 12px 14px;
    }

    .sys-pr-page__range-label {
      width: 100%;
    }

    .sys-pr-page__search {
      width: 100%;
      justify-self: stretch;
    }

    .sys-pr-page__sortbar {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 16px;
    }

    .sys-pr-page__sort {
      justify-content: center;
      padding: 0 8px;
      font-size: 13px;
    }

    .sys-pr-page__empty {
      min-height: 308px;
      padding: 30px 0 58px;
    }

    .sys-pr-page__empty-figure {
      width: min(132px, 42vw);
    }
  }
</style>
