<ReplicaLayout
  title={pageTitle}
  description={pageDescription}
  route="/tcn/"
  locale="zh-Hant"
  image="/mirror/31680567.s21i.faiusr.com_4_2_ABUIABAEGAAgxJiQqYortvS7AMw7w448gQ.png"
>
  <div class="tcn-home">
    <section class="tcn-hero">
      <picture class="tcn-hero__art">
        <source media="(max-width: 768px)" srcset={sourceImages.heroMobile} />
        <img src={sourceImages.heroDesktop} alt="" />
      </picture>
      <div class="tcn-hero__content">
        <h1>馬上進行中國象棋<br />在線對戰吧！</h1>
        <div class="tcn-hero__actions">
          <a class="tcn-button" href="https://play.xiangqi.com/lobby?lang=zh-Hans" target="_blank" rel="noreferrer">開始遊戲</a>
          <a class="tcn-button" href="https://play.xiangqi.com/account/signin?lang=zh-Hans" target="_blank" rel="noreferrer">登錄/註冊</a>
        </div>
      </div>
    </section>

    <section class="tcn-band">
      <div class="tcn-shell tcn-band__grid">
        <div class="tcn-band__image">
          <img src={sourceImages.introGlobe} alt="免費象棋在線玩示意圖" loading="lazy" />
        </div>
        <div class="tcn-band__copy">
          <h2>免費象棋在線玩</h2>
          {introParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </section>

    <section class="tcn-shell tcn-feature">
      <div class="tcn-feature__copy">
        <h2>{featureLead.title}</h2>
        {featureLead.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="tcn-feature__image">
        <img src={sourceImages.featureVersus} alt="中國象棋雙人對戰示意圖" loading="lazy" />
      </div>
    </section>

    <section class="tcn-shell tcn-sections">
      {sections.map((section, index) => (
        <article class="tcn-section">
          <div class="tcn-section__copy">
            <h2>{section.title}</h2>
            {section.body.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </article>
      ))}
    </section>

    <section class="tcn-articles">
      <div class="tcn-shell">
        <div class="tcn-section-heading">
          <h2>教學文章</h2>
          <a href="/tcn/sys-nr/">更多</a>
        </div>
        <div class="tcn-article-grid">
          {articleCards.map((card) => (
            <a class="tcn-article-card" href={card.href}>
              <img src={card.image} alt={card.title} loading="lazy" />
              <div class="tcn-article-card__body">
                <h3>{card.title}</h3>
                <p>{card.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="tcn-faq">
      <div class="tcn-shell">
        <h2>常見問題</h2>
        <div class="tcn-faq__list">
          {faqs.map((item, index) => (
            <details class="tcn-faq__item" open={index === 0}>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </div>
</ReplicaLayout>

<style>
  :global(body[data-route="/tcn/"]) {
    background: #ede8e0;
    color: #664f4c;
  }

  .tcn-home {
    --tcn-red: #be342d;
    --tcn-red-dark: #8f261f;
    --tcn-paper: #ede8e0;
    --tcn-text: #664f4c;
    --tcn-shell: min(1120px, calc(100vw - 2rem));
  }

  .tcn-shell {
    width: var(--tcn-shell);
    margin: 0 auto;
  }

  .tcn-hero {
    position: relative;
    min-height: 470px;
    overflow: clip;
    background: linear-gradient(180deg, #f0ebe4 0%, #f0ebe4 58%, #e6ddd1 100%);
  }

  .tcn-hero__art {
    position: absolute;
    inset: 0;
    display: block;
  }

  .tcn-hero__art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .tcn-hero__content {
    position: relative;
    z-index: 1;
    width: var(--tcn-shell);
    margin: 0 auto;
    padding: 6.25rem 0 4.25rem;
    text-align: center;
  }

  .tcn-hero h1 {
    margin: 0;
    font-size: clamp(2.3rem, 4.8vw, 4.35rem);
    line-height: 1.12;
    color: var(--tcn-text);
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.45);
  }

  .tcn-hero__actions {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 2.5rem;
  }

  .tcn-button {
    min-width: 168px;
    padding: 0.95rem 1.8rem;
    border: 5px solid #fff;
    border-radius: 999px;
    background: #be342d;
    color: #fff;
    font-size: 1.1rem;
    text-decoration: none;
    box-shadow: 0 12px 30px rgba(95, 21, 18, 0.18);
    transition: transform 160ms ease, background 160ms ease;
  }

  .tcn-button:hover {
    transform: translateY(-2px);
    background: #c75851;
  }

  .tcn-band {
    background: var(--tcn-red);
    color: #fff;
    padding: 4rem 0 4.5rem;
  }

  .tcn-band__grid,
  .tcn-feature {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) minmax(0, 1.15fr);
    gap: clamp(1.5rem, 4vw, 4.25rem);
    align-items: center;
  }

  .tcn-band__image img,
  .tcn-feature__image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .tcn-band__copy h2,
  .tcn-feature__copy h2,
  .tcn-section h2,
  .tcn-section-heading h2,
  .tcn-faq h2 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 3.1rem);
    line-height: 1.16;
  }

  .tcn-band__copy p,
  .tcn-feature__copy p,
  .tcn-section p,
  .tcn-faq p {
    margin: 0 0 1rem;
    font-size: 1.08rem;
    line-height: 2;
  }

  .tcn-feature {
    padding: 4rem 0 2rem;
  }

  .tcn-sections {
    padding: 0.5rem 0 3rem;
  }

  .tcn-section {
    padding: 1.35rem 0;
  }

  .tcn-articles {
    border-top: 1px solid rgba(102, 79, 76, 0.35);
    padding: 3.5rem 0 4rem;
  }

  .tcn-section-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .tcn-section-heading a {
    color: var(--tcn-text);
    text-decoration: none;
    font-weight: 700;
  }

  .tcn-article-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .tcn-article-card {
    display: block;
    overflow: hidden;
    background: #f5f0e7;
    border: 1px solid rgba(102, 79, 76, 0.12);
    color: inherit;
    text-decoration: none;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .tcn-article-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 35px rgba(83, 55, 47, 0.12);
  }

  .tcn-article-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .tcn-article-card__body {
    padding: 1rem 1rem 1.25rem;
  }

  .tcn-article-card__body h3 {
    margin: 0 0 0.7rem;
    font-size: 1.2rem;
    line-height: 1.35;
  }

  .tcn-article-card__body p {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.8;
  }

  .tcn-faq {
    border-top: 1px solid rgba(102, 79, 76, 0.35);
    padding: 3.75rem 0 4.5rem;
  }

  .tcn-faq__list {
    display: grid;
    gap: 0.75rem;
  }

  .tcn-faq__item {
    border-bottom: 1px solid rgba(102, 79, 76, 0.18);
    background: rgba(255, 255, 255, 0.2);
  }

  .tcn-faq__item summary {
    cursor: pointer;
    list-style: none;
    padding: 1rem 0;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .tcn-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .tcn-faq__item p {
    padding: 0 0 1rem;
  }

  @media (max-width: 900px) {
    .tcn-band__grid,
    .tcn-feature,
    .tcn-article-grid {
      grid-template-columns: 1fr;
    }

    .tcn-hero {
      min-height: 360px;
    }

    .tcn-hero__content {
      padding: 4.5rem 0 3rem;
    }
  }

  @media (max-width: 640px) {
    .tcn-home {
      --tcn-shell: calc(100vw - 1.25rem);
    }

    .tcn-band {
      padding: 3rem 0 3.25rem;
    }

    .tcn-band__copy p,
    .tcn-feature__copy p,
    .tcn-section p,
    .tcn-faq p {
      font-size: 1rem;
      line-height: 1.85;
    }

    .tcn-button {
      width: 100%;
      max-width: 280px;
    }
  }
</style>
