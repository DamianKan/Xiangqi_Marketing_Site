---
import ReplicaLayout from "../../layouts/ReplicaLayout.astro";

const ctaHref = "https://play.xiangqi.com/account/signin?lang=zh-Hans";
const hero = "/mirror/31680567.s21i.faiusr.com_4_2_ABUIABAEGAAgxJiQqQYortvS7AMw7w448gQ.png";
---

<ReplicaLayout
  title="注册"
  description="通过相弈象棋软件平台便可以轻松实现线上中国象棋对弈，中国象棋在线玩，不受时间地点限制在线下象棋。马上进行在线象棋对战吧！"
  route="/tcn/sys-login/"
  locale="zh-Hant"
>
  <section class="sys-login-hero" style={`--sys-login-hero-image: url('${hero}')`}>
    <div class="sys-login-hero__rail" aria-hidden="true">
      <div class="sys-login-hero__rail-icon sys-login-hero__rail-icon--profile"></div>
      <div class="sys-login-hero__rail-icon sys-login-hero__rail-icon--service"></div>
      <a class="sys-login-hero__rail-login" href={ctaHref} target="_blank" rel="noreferrer">登录</a>
    </div>

    <div class="sys-login-hero__content">
      <p class="sys-login-hero__eyebrow">XIANGQI.COM 相弈象棋</p>
      <h1>
        <span>马上进行中国象棋</span>
        <span>在线对战吧！</span>
      </h1>
      <p class="sys-login-hero__copy">
        使用网页或 App 即可开始对弈、学习与交流，延续源页当前入口功能与内容表达。
      </p>
      <div class="sys-login-hero__actions">
        <a class="sys-login-hero__cta" href={ctaHref} target="_blank" rel="noreferrer">登录/注册</a>
        <a class="sys-login-hero__download" href="/tcn/mobile/">下载APP</a>
      </div>
    </div>
  </section>
</ReplicaLayout>

<style is:global>
  body[data-route="/tcn/sys-login/"] {
    background:
      radial-gradient(circle at top center, rgba(255, 255, 255, 0.42), transparent 28%),
      linear-gradient(180deg, #f5eee6 0%, #ede6dd 100%);
  }

  body[data-route="/tcn/sys-login/"] .replica-header {
    box-shadow: 0 10px 28px rgba(92, 28, 24, 0.16);
  }

  body[data-route="/tcn/sys-login/"] .replica-footer {
    margin-top: 0;
  }

  .sys-login-hero {
    --hero-shadow: 0 30px 70px rgba(84, 38, 33, 0.14);
    position: relative;
    width: 100%;
    min-height: 620px;
    margin: 0 auto 44px;
    border-radius: 0;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(251, 245, 238, 0.24), rgba(247, 239, 231, 0.08)),
      var(--sys-login-hero-image) center center / cover no-repeat;
    box-shadow: none;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 52px 24px;
  }

  .sys-login-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at center 22%, rgba(255, 255, 255, 0.34), transparent 21%),
      linear-gradient(90deg, rgba(244, 233, 223, 0.28) 0%, rgba(244, 233, 223, 0.05) 24%, rgba(244, 233, 223, 0.03) 74%, rgba(244, 233, 223, 0.22) 100%);
    pointer-events: none;
  }

  .sys-login-hero__content {
    position: relative;
    z-index: 1;
    max-width: 760px;
    text-align: center;
    padding: 10px 24px 18px;
  }

  .sys-login-hero__eyebrow {
    margin: 0 0 16px;
    color: rgba(109, 86, 82, 0.86);
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.18em;
  }

  .sys-login-hero h1 {
    margin: 0;
    color: #6b5751;
    font-size: clamp(52px, 5.4vw, 104px);
    line-height: 0.98;
    font-weight: 800;
  }

  .sys-login-hero h1 span {
    display: block;
  }

  .sys-login-hero__copy {
    width: min(100%, 520px);
    margin: 18px auto 0;
    color: rgba(107, 87, 81, 0.86);
    font-size: 16px;
    line-height: 1.75;
  }

  .sys-login-hero__actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .sys-login-hero__cta,
  .sys-login-hero__download {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 176px;
    height: 56px;
    padding: 0 26px;
    border-radius: 999px;
    font-size: 17px;
    font-weight: 800;
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }

  .sys-login-hero__cta {
    border: 4px solid #fff;
    background: linear-gradient(180deg, #d7483e 0%, #bf352d 100%);
    color: #fff;
    box-shadow: 0 16px 28px rgba(139, 34, 28, 0.24);
  }

  .sys-login-hero__download {
    background: rgba(255, 252, 248, 0.84);
    color: #765b54;
    border: 1px solid rgba(122, 88, 78, 0.18);
    box-shadow: 0 14px 24px rgba(124, 95, 85, 0.08);
  }

  .sys-login-hero__cta:hover,
  .sys-login-hero__download:hover {
    transform: translateY(-2px);
  }

  .sys-login-hero__rail {
    position: absolute;
    top: 30px;
    left: 28px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .sys-login-hero__rail-icon {
    width: 28px;
    height: 44px;
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid rgba(109, 86, 82, 0.14);
    position: relative;
  }

  .sys-login-hero__rail-icon::before,
  .sys-login-hero__rail-icon::after {
    content: "";
    position: absolute;
  }

  .sys-login-hero__rail-icon--profile::before {
    left: 8px;
    top: 8px;
    width: 8px;
    height: 8px;
    border: 1.4px solid #8d8d8d;
    border-radius: 50%;
  }

  .sys-login-hero__rail-icon--profile::after {
    left: 6px;
    bottom: 8px;
    width: 12px;
    height: 7px;
    border: 1.4px solid #8d8d8d;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom: 0;
  }

  .sys-login-hero__rail-icon--service::before {
    left: 7px;
    top: 11px;
    width: 12px;
    height: 8px;
    border: 1.4px solid #8d8d8d;
    border-radius: 2px;
  }

  .sys-login-hero__rail-icon--service::after {
    left: 11px;
    bottom: 10px;
    width: 6px;
    height: 6px;
    border-left: 1.4px solid #8d8d8d;
    border-bottom: 1.4px solid #8d8d8d;
    transform: skewX(-25deg);
  }

  .sys-login-hero__rail-login {
    margin-top: 24px;
    writing-mode: vertical-rl;
    text-orientation: upright;
    background: linear-gradient(180deg, #e15349 0%, #d43b31 100%);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 8px 5px;
    line-height: 1.1;
    border-radius: 999px;
    box-shadow: 0 14px 24px rgba(109, 24, 20, 0.16);
  }

  @media (max-width: 1080px) {
    .sys-login-hero {
      min-height: 560px;
      background-position: 34% center;
    }

    .sys-login-hero h1 {
      font-size: clamp(44px, 6vw, 84px);
    }
  }

  @media (max-width: 820px) {
    .sys-login-hero {
      width: 100%;
      min-height: 500px;
      margin-top: 0;
      padding: 40px 18px 70px;
      background-position: 30% center;
    }

    .sys-login-hero__rail {
      display: none;
    }

    .sys-login-hero__content {
      max-width: 100%;
      padding-inline: 8px;
    }

    .sys-login-hero__copy {
      width: 100%;
    }

  }

  @media (max-width: 560px) {
    .sys-login-hero {
      min-height: 440px;
      margin-bottom: 28px;
      padding-top: 28px;
      background-position: 24% center;
      background-size: auto 100%;
    }

    .sys-login-hero__eyebrow {
      font-size: 12px;
      letter-spacing: 0.14em;
    }

    .sys-login-hero h1 {
      font-size: clamp(34px, 12vw, 54px);
      line-height: 1.04;
    }

    .sys-login-hero__copy {
      font-size: 15px;
    }

    .sys-login-hero__actions {
      flex-direction: column;
      align-items: center;
    }

    .sys-login-hero__cta,
    .sys-login-hero__download {
      width: min(100%, 260px);
      height: 52px;
    }
  }
</style>
