---

<ReplicaLayout
  title="新闻动态 - 相弈象棋"
  description="复刻源站当前 sys-nr 页面内容，包含新闻动态与教学文章列表、搜索筛选以及本地可用的正确跳转。"
  route="/tcn/sys-nr/"
  locale="zh-Hant"
  image={placeholderImage}
>
  <section class="sys-nr-page">
    <div class="sys-nr-shell">
      <div class="sys-nr-toolbar">
        <h1>教学文章</h1>
        <label class="sys-nr-search" aria-label="搜索教学文章">
          <span class="sr-only">搜索教学文章</span>
          <input id="sys-nr-search-input" type="search" placeholder="请输入关键字" autocomplete="off" />
          <span class="sys-nr-search__icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" focusable="false">
              <circle cx="8.5" cy="8.5" r="5.5"></circle>
              <path d="M12.8 12.8L17 17"></path>
            </svg>
          </span>
        </label>
      </div>

      <div class="sys-nr-list" id="sys-nr-list">
        {articles.map((article) => {
          const isExternal = article.href.startsWith("http");
          return (
            <a
              class="sys-nr-item"
              href={article.href}
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noreferrer" : undefined}
              aria-label={article.title}
              data-title={article.title}
              data-excerpt={article.excerpt}
              data-date={article.date}
              data-tag={article.tag}
            >
              <div class="sys-nr-item__thumb">
                <img src={article.image} alt={article.title} loading="lazy" />
              </div>
              <div class="sys-nr-item__body">
                <div class="sys-nr-item__head">
                  <h2>{article.title}</h2>
                  <time datetime={article.date}>{article.date}</time>
                </div>
                <p class="sys-nr-item__excerpt">{article.excerpt}</p>
                {article.tag && (
                  <div class="sys-nr-item__meta">
                    <span>{article.tag}</span>
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>

      <p class="sys-nr-empty" id="sys-nr-empty" hidden>未搜索到相关结果</p>
    </div>
  </section>

  <script is:inline>
    const input = document.getElementById("sys-nr-search-input");
    const items = Array.from(document.querySelectorAll(".sys-nr-item"));
    const empty = document.getElementById("sys-nr-empty");

    if (input && empty) {
      const applyFilter = () => {
        const keyword = input.value.trim().toLowerCase();
        let visibleCount = 0;

        items.forEach((item) => {
          const haystack = [
            item.getAttribute("data-title") || "",
            item.getAttribute("data-excerpt") || "",
            item.getAttribute("data-date") || "",
            item.getAttribute("data-tag") || ""
          ]
            .join(" ")
            .toLowerCase();

          const matched = !keyword || haystack.includes(keyword);
          item.toggleAttribute("hidden", !matched);
          if (matched) visibleCount += 1;
        });

        empty.hidden = visibleCount > 0;
      };

      input.addEventListener("input", applyFilter);
    }
  </script>
</ReplicaLayout>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  body[data-route="/tcn/sys-nr/"] {
    background: #ede8e0;
  }

  body[data-route="/tcn/sys-nr/"] main {
    min-height: 0;
  }

  .sys-nr-page {
    padding: 24px 0 12px;
    background: #ede8e0;
  }

  .sys-nr-shell {
    width: min(1120px, calc(100vw - 40px));
    margin: 0 auto;
  }

  .sys-nr-toolbar {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 22px;
  }

  .sys-nr-toolbar h1 {
    margin: 0;
    color: #664f4c;
    font-size: clamp(30px, 3.3vw, 36px);
    line-height: 1.15;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .sys-nr-search {
    position: relative;
    width: min(100%, 360px);
    display: block;
  }

  .sys-nr-search input {
    width: 100%;
    height: 42px;
    padding: 0 48px 0 14px;
    border: 1px solid rgba(192, 181, 170, 0.9);
    background: #fff;
    color: #3f3532;
    font: inherit;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .sys-nr-search input:focus {
    border-color: #ef4136;
    box-shadow: 0 0 0 3px rgba(239, 65, 54, 0.12);
  }

  .sys-nr-search input::placeholder {
    color: #a49188;
  }

  .sys-nr-search__icon {
    position: absolute;
    top: 50%;
    right: 14px;
    width: 18px;
    height: 18px;
    color: #4f4540;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .sys-nr-search__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .sys-nr-list {
    display: grid;
    gap: 0;
    border: 1px solid rgba(213, 204, 194, 0.9);
    background: #fff;
  }

  .sys-nr-item {
    display: grid;
    grid-template-columns: 188px minmax(0, 1fr);
    gap: 24px;
    padding: 24px;
    border-bottom: 1px solid rgba(230, 224, 218, 0.95);
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  .sys-nr-item:last-child {
    border-bottom: 0;
  }

  .sys-nr-item:hover {
    background: rgba(252, 249, 244, 0.85);
  }

  .sys-nr-item__thumb {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f5f0ea;
    border: 1px solid rgba(222, 214, 205, 0.92);
  }

  .sys-nr-item__thumb img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .sys-nr-item__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }

  .sys-nr-item__head h2 {
    margin: 0;
    color: #352d2a;
    font-size: 23px;
    line-height: 1.35;
    font-weight: 600;
  }

  .sys-nr-item__head time {
    flex: 0 0 auto;
    color: #8e7c73;
    font-size: 14px;
    line-height: 1.4;
  }

  .sys-nr-item__excerpt {
    margin: 12px 0 0;
    color: #5f5651;
    font-size: 15px;
    line-height: 1.85;
  }

  .sys-nr-item__meta {
    margin-top: 14px;
  }

  .sys-nr-item__meta span {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    color: #8a372f;
    font-size: 13px;
    background: rgba(239, 65, 54, 0.08);
    border: 1px solid rgba(239, 65, 54, 0.14);
  }

  .sys-nr-empty {
    margin: 22px 0 0;
    color: #4d403c;
    font-size: 15px;
    line-height: 1.6;
    text-align: center;
  }

  .sys-nr-item[hidden] {
    display: none;
  }

  @media (max-width: 900px) {
    .sys-nr-page {
      padding-top: 18px;
    }

    .sys-nr-shell {
      width: min(100vw - 30px, 1120px);
    }

    .sys-nr-toolbar {
      align-items: stretch;
      flex-direction: column;
      margin-bottom: 18px;
    }

    .sys-nr-search {
      width: 100%;
    }

    .sys-nr-item {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 20px;
    }

    .sys-nr-item__thumb {
      max-width: 360px;
    }

    .sys-nr-item__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .sys-nr-item__head h2 {
      font-size: 21px;
    }
  }

  @media (max-width: 560px) {
    .sys-nr-page {
      padding-top: 14px;
    }

    .sys-nr-shell {
      width: calc(100vw - 24px);
    }

    .sys-nr-toolbar h1 {
      font-size: 28px;
    }

    .sys-nr-item {
      padding: 16px;
    }

    .sys-nr-item__head h2 {
      font-size: 19px;
    }

    .sys-nr-item__excerpt {
      font-size: 14px;
      line-height: 1.75;
    }
  }
</style>
