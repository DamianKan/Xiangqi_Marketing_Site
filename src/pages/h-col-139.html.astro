---
import ReplicaHeader from "../components/replica/ReplicaHeader.astro";
import StructuredData from "../components/StructuredData.astro";
import { replicaAssets } from "../data/replica/assets";
import { buildWebPageStructuredData } from "../utils/structuredData";
import "../styles/replica.css";

const pageTitle = "Xiangqi.com 相弈象棋";
const pageDescription = "Xiangqi.com 页脚导航页面。";
const pageStructuredData = buildWebPageStructuredData({
  title: pageTitle,
  description: pageDescription,
  canonical: "https://www.zh.xiangqi.com/h-col-139.html",
  imageUrl: "https://www.zh.xiangqi.com/mirror/31680567.s21i.faiusr.com_5_2_ABUIABAFGAAgwIXIqQYo5KSiSDCRATiRAQ.ico"
});

const footerColumns = [
  {
    title: "关于",
    links: [
      { label: "我们的故事", href: "/about/" },
      { label: "我们的团队", href: "/team/" },
      { label: "产品路线图", href: "/roadmap/" },
      { label: "联系我们", href: "/contact/" }
    ]
  },
  {
    title: "帮助",
    links: [
      { label: "象棋规则", href: "/how-to-play/" },
      { label: "棋子与走法", href: "/pieces-and-moves/" },
      { label: "等级分系统", href: "/rating/" },
      { label: "象棋走法限制", href: "/limits/" }
    ]
  },
  {
    title: "更多",
    links: [
      { label: "商品周边", href: "/shop/" },
      { label: "资源", href: "/resources/" },
      { label: "公平对弈政策", href: "/fair-play/" },
      { label: "文明政策", href: "/polite/" },
      { label: "服务条款", href: "/terms/" },
      { label: "隐私政策", href: "/privacy/" }
    ]
  }
];

const downloadBadges = [
  {
    label: "Google Play",
    href: "https://play.google.com/store/apps/details?id=com.xiangqimobile",
    image: replicaAssets.downloadBadgeGoogle
  },
  {
    label: "Android APK",
    href: "https://github.com/Littline/xiangqi_apk/releases/download/v1.0/Xiangqi-v2.1.4-signed-China.apk",
    image: replicaAssets.downloadBadgeApk
  },
  {
    label: "App Store",
    href: "https://apps.apple.com/app/xiangqi-com-chinese-chess/id1557911460",
    image: replicaAssets.downloadBadgeApple
  }
];

const socialLinks = [
  { label: "知乎", href: "https://www.zhihu.com/people/-xiangqi-com" },
  { label: "微信公众号", href: "https://mp.weixin.qq.com/s/SM9sHQp_9DeZG-vEvD-M7A" },
  { label: "哔哩哔哩", href: "https://space.bilibili.com/3493257524808089?spm_id_from=333.337.search-card.all.click" },
  { label: "小红书", href: "https://www.xiaohongshu.com/user/profile/624012d80000000021025494" }
];

const whatsappHref = "https://chat.whatsapp.com/FwV8PQjH1xVKKfocOGgKl5";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href="https://www.zh.xiangqi.com/h-col-139.html" />
    <link rel="icon" href="/mirror/31680567.s21i.faiusr.com_5_2_ABUIABAFGAAgwIXIqQYo5KSiSDCRATiRAQ.ico" />
    <StructuredData data={pageStructuredData} />
    <style>
      :root {
        --page-bg: #ca362c;
        --page-bg-dark: #bf3027;
        --text-white: #ffffff;
        --text-white-soft: rgba(255, 255, 255, 0.92);
        --text-white-muted: rgba(255, 255, 255, 0.8);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
        background: var(--page-bg);
        color: var(--text-white);
      }

      body {
        line-height: 1.4;
      }

      .replica-header {
        position: sticky;
        top: 0;
        z-index: 30;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
        text-underline-offset: 0.16em;
      }

      .page {
        min-height: 100vh;
        background: linear-gradient(180deg, var(--page-bg) 0%, var(--page-bg-dark) 100%);
      }

      .shell {
        width: min(1220px, calc(100% - 48px));
        margin: 0 auto;
      }

      .content {
        padding: 58px 0 28px;
      }

      .hero {
        text-align: center;
        margin-bottom: 54px;
      }

      .hero h1 {
        margin: 0;
        font-size: clamp(40px, 4vw, 54px);
        line-height: 1.1;
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .columns {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 130px;
        align-items: start;
        margin: 0 auto 64px;
      }

      .column {
        text-align: center;
      }

      .column h2 {
        margin: 0 0 30px;
        font-size: 19px;
        font-weight: 700;
      }

      .column ul {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .column li + li {
        margin-top: 18px;
      }

      .column a {
        color: var(--text-white-soft);
        font-size: 16px;
      }

      .downloads {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 160px;
        flex-wrap: wrap;
        margin-bottom: 42px;
      }

      .downloads a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 180ms ease, opacity 180ms ease;
      }

      .downloads a:hover {
        transform: translateY(-2px);
        opacity: 0.95;
      }

      .downloads img {
        display: block;
        height: 54px;
        width: auto;
      }

      .meta {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 20px;
        font-size: 12px;
        color: var(--text-white-muted);
      }

      .meta__left {
        justify-self: start;
      }

      .meta__center {
        justify-self: center;
        text-align: center;
      }

      .meta__center span,
      .meta__center a {
        margin-right: 10px;
      }

      .meta__center a:last-child {
        margin-right: 0;
      }

      .meta__right {
        justify-self: end;
      }

      .meta a {
        color: var(--text-white);
      }

      @media (max-width: 1100px) {
        .columns {
          gap: 56px;
        }

        .downloads {
          gap: 36px;
        }

        .meta {
          grid-template-columns: 1fr;
          gap: 14px;
          text-align: center;
        }

        .meta__left,
        .meta__center,
        .meta__right {
          justify-self: center;
        }
      }

      @media (max-width: 820px) {
        .content {
          padding-top: 42px;
        }

        .hero {
          margin-bottom: 36px;
        }

        .columns {
          grid-template-columns: 1fr;
          gap: 40px;
          margin-bottom: 44px;
        }

        .downloads {
          gap: 20px;
        }
      }

      @media (max-width: 520px) {
        .shell {
          width: calc(100% - 24px);
        }

        .hero h1 {
          font-size: 34px;
        }

        .downloads a {
          width: 100%;
        }

        .downloads img {
          height: auto;
          width: min(100%, 184px);
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <ReplicaHeader locale="zh-CN" />

      <main class="content">
        <section class="shell" aria-labelledby="footer-page-title">
          <div class="hero">
            <h1 id="footer-page-title">Xiangqi.com 相弈象棋</h1>
          </div>

          <div class="columns">
            {footerColumns.map((column) => (
              <section class="column" aria-labelledby={`col-${column.title}`}>
                <h2 id={`col-${column.title}`}>{column.title}</h2>
                <ul>
                  {column.links.map((link) => (
                    <li><a href={link.href}>{link.label}</a></li>
                  ))}
                </ul>
              </section>
            ))}
          </div>

          <div class="downloads" aria-label="下载渠道">
            {downloadBadges.map((badge) => (
              <a href={badge.href} target="_blank" rel="noreferrer" aria-label={badge.label}>
                <img src={badge.image} alt={badge.label} loading="lazy" />
              </a>
            ))}
          </div>

          <div class="meta">
            <div class="meta__left">©2024 - 相弈象棋 版权所有</div>

            <div class="meta__center">
              <span>关注我们:</span>
              {socialLinks.map((link) => (
                <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
              ))}
            </div>

            <div class="meta__right">
              <a href={whatsappHref} target="_blank" rel="noreferrer">来 WhatsApp 和我们聊天</a>
            </div>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
