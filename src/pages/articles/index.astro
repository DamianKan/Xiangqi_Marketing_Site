---
import AhrefsAnalytics from "../../components/AhrefsAnalytics.astro";
import StructuredData from "../../components/StructuredData.astro";
import { buildWebPageStructuredData } from "../../utils/structuredData";

const target = "/sys-nr/";
const pageTitle = "正在跳转 - 相弈象棋";
const pageStructuredData = buildWebPageStructuredData({
  title: pageTitle,
  description: "相弈象棋教学文章页跳转入口。",
  canonical: "https://www.zh.xiangqi.com/articles/"
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>{pageTitle}</title>
    <StructuredData data={pageStructuredData} />
    <AhrefsAnalytics />
  </head>
  <body>
    <p><a href={target}>前往教学文章页</a></p>
    <script>
      window.location.replace("/sys-nr/");
    </script>
  </body>
</html>
