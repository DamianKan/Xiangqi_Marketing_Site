---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="在线对弈 - 相弈象棋" description="本地在线对弈入口说明页。" canonicalPath="/play/">
  <section class="section">
    <div class="container split">
      <div class="content-panel">
        <p class="eyebrow">Play</p>
        <h1>在线对弈</h1>
        <p>这里是本地预览版的在线对弈入口。为了满足本地化要求，当前按钮不跳转到外部大厅。</p>
        <div class="cta-row">
          <a class="btn btn-primary" href="/">返回首页</a>
          <a class="btn btn-secondary" href="/how-to-play/">先看规则</a>
        </div>
      </div>
      <img src="/mirror/31680567.s21i.faiusr.com_4_2_ABUIABAEGAAg87OYqQYo0au00AIw1ws41ws.png" alt="象棋对弈入口" />
    </div>
  </section>
</BaseLayout>
