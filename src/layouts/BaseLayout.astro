---
import ReplicaHeader from "../components/replica/ReplicaHeader.astro";
import ReplicaFooter from "../components/replica/ReplicaFooter.astro";
import AhrefsAnalytics from "../components/AhrefsAnalytics.astro";
import StructuredData from "../components/StructuredData.astro";
import { buildWebPageStructuredData, compactStructuredData } from "../utils/structuredData";
import "../styles/global.css";
import "../styles/replica.css";
import site from "../data/site.json";

interface MetaProps {
  title: string;
  description: string;
  canonicalPath: string;
  h1?: string;
  image?: string;
  noindex?: boolean;
  structuredData?: object | object[];
}

const {
  title,
  description,
  canonicalPath,
  image = "/images/xiangqi-og.svg",
  noindex = false,
  structuredData = []
} = Astro.props as MetaProps;

const canonical = new URL(canonicalPath, site.siteUrl).toString();
const imageUrl = new URL(image, site.siteUrl).toString();
const structuredDataItems = compactStructuredData(structuredData);
const pageStructuredData =
  structuredDataItems.length > 0
    ? structuredDataItems
    : buildWebPageStructuredData({ title, description, canonical, imageUrl });
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <StructuredData data={pageStructuredData} />
    <AhrefsAnalytics />
  </head>
  <body data-locale="zh-CN" data-route={canonicalPath}>
    <ReplicaHeader locale="zh-CN" />
    <main>
      <slot />
    </main>
    <ReplicaFooter locale="zh-CN" />
  </body>
</html>
