---
import ReplicaHeader from "../components/replica/ReplicaHeader.astro";
import ReplicaFooter from "../components/replica/ReplicaFooter.astro";
import StructuredData from "../components/StructuredData.astro";
import { getLocaleConfig } from "../data/replica/locales";
import type { ReplicaLocale } from "../data/replica/types";
import { buildWebPageStructuredData, compactStructuredData } from "../utils/structuredData";
import "../styles/replica.css";

interface Props {
  title: string;
  description: string;
  route: string;
  locale: ReplicaLocale;
  image?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
  structuredData?: object | object[];
}

const {
  title,
  description,
  route,
  locale,
  image = "/mirror/31680567.s21i.faiusr.com_4_2_ABUIABAEGAAgxJiQqYortvS7AMw7w448gQ.png",
  hideHeader = false,
  hideFooter = false,
  structuredData = []
} = Astro.props as Props;
const localeConfig = getLocaleConfig(locale);
const siteUrl = "https://www.zh.xiangqi.com";
const canonical = new URL(route, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const structuredDataItems = compactStructuredData(structuredData);
const pageStructuredData =
  structuredDataItems.length > 0
    ? structuredDataItems
    : buildWebPageStructuredData({ title, description, canonical, imageUrl });
---

<!doctype html>
<html lang={localeConfig.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/mirror/31680567.s21i.faiusr.com_5_2_ABUIABAFGAAgwIXIqQYo5KSiSDCRATiRAQ.ico" />
    <StructuredData data={pageStructuredData} />
  </head>
  <body
    data-locale={locale}
    data-route={route}
    class:list={[
      route === "/" && "page-home",
      route === "/slash/" && "page-slash",
      route === "/contributors/" && "page-contributors"
    ]}
  >
    {!hideHeader && route !== "/slash/" && route !== "/contributors/" && <ReplicaHeader locale={locale} />}
    <main>
      <slot />
    </main>
    {!hideFooter && route !== "/slash/" && route !== "/contributors/" && <ReplicaFooter locale={locale} />}
  </body>
</html>
